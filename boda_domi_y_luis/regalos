<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mesa de regalos · Domi & Luis</title>
<meta name="description" content="Mesa de regalos para la luna de miel de Domi & Luis · 03 · Octubre · 2026">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cdefs%3E%3CradialGradient id='mg' cx='38%25' cy='38%25' r='65%25'%3E%3Cstop offset='0%25' stop-color='%23EDD4A0'/%3E%3Cstop offset='100%25' stop-color='%23C49030'/%3E%3C/radialGradient%3E%3Cmask id='mm'%3E%3Ccircle cx='16' cy='16' r='13' fill='white'/%3E%3Ccircle cx='22' cy='15' r='12' fill='black'/%3E%3C/mask%3E%3C/defs%3E%3Ccircle cx='16' cy='16' r='13' fill='url(%23mg)' mask='url(%23mm)'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --cream:#F7EDD8; --linen:#F0E2C0; --warm:#EDD4A0;
  --terra:#C45A1A; --sienna:#8B3210; --burg:#4A1A08;
  --sage:#6B7A42;  --forest:#243D1E; --gold:#C49030;
  --dark:#0E0906;  --dark2:#1A0E06; --dark3:#0C1408;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{overflow-x:hidden}
html{scroll-behavior:smooth}
body{font-family:'Jost',sans-serif;font-weight:300;color:#F2E4C4;
  background:linear-gradient(170deg,#0E0906 0%,#1A0E06 35%,#0C1408 70%,#0E0906 100%);
  min-height:100vh;position:relative;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  background-size:180px;pointer-events:none;z-index:998;opacity:.6}

#starfield{position:fixed;inset:0;pointer-events:none;z-index:0}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:300;padding:18px 32px;
  display:flex;align-items:center;justify-content:space-between;transition:background .4s,box-shadow .4s}
nav.scrolled{background:rgba(10,6,3,.92);backdrop-filter:blur(12px);box-shadow:0 1px 0 rgba(196,144,48,.15)}
.nav-logo{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.3rem;color:var(--gold)}
.nav-back{font-family:'Jost',sans-serif;font-size:.62rem;letter-spacing:.24em;text-transform:uppercase;
  color:rgba(247,237,216,.55);text-decoration:none;transition:color .2s;
  display:inline-flex;align-items:center;gap:8px}
.nav-back:hover{color:var(--gold)}
.nav-back-ic{font-size:.95rem;transition:transform .2s}
.nav-back:hover .nav-back-ic{transform:translateX(-3px)}
@media(max-width:600px){
  nav{padding:14px 18px}
  .nav-logo{font-size:1.1rem}
  .nav-back{font-size:.55rem;letter-spacing:.2em}
}

/* ── REVEAL ── */
.rv{opacity:0;transform:translateY(24px);transition:opacity .85s ease,transform .85s ease}
.rv.vis{opacity:1;transform:translateY(0)}
.d1{transition-delay:.12s}.d2{transition-delay:.24s}.d3{transition-delay:.36s}.d4{transition-delay:.5s}
.d5{transition-delay:.6s}.d6{transition-delay:.7s}

/* ── HERO ── */
.hero{position:relative;padding:120px 24px 60px;text-align:center;z-index:5}
.hero-illu{position:absolute;inset:0;pointer-events:none;z-index:1;overflow:hidden}
.hero-content{position:relative;z-index:5;max-width:720px;margin:0 auto}

.lbl{font-family:'Jost',sans-serif;font-size:.72rem;letter-spacing:.32em;
  text-transform:uppercase;color:rgba(196,144,48,.85);margin-bottom:18px}
.title{font-family:'Cormorant Garamond',serif;font-weight:300;font-style:italic;
  font-size:clamp(2.2rem,6vw,3.6rem);color:#F2E4C4;line-height:1.1;
  letter-spacing:.01em;margin-bottom:22px}
.title .amp{color:var(--gold);font-weight:300}
.gd{display:flex;align-items:center;justify-content:center;gap:8px;margin:20px auto 28px;max-width:280px}
.gl{flex:1;height:1px;background:linear-gradient(to right,transparent,rgba(196,144,48,.5),transparent)}
.gl.r{background:linear-gradient(to left,transparent,rgba(196,144,48,.5),transparent)}
.gdd{width:3px;height:3px;background:var(--gold);border-radius:50%}
.gdm{width:5px;height:5px;background:var(--gold);border-radius:50%;opacity:.85}

.sub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.15rem;
  color:var(--gold);margin-bottom:30px}

.body-txt{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.12rem;
  line-height:1.78;color:#E8D8B8;max-width:540px;margin:0 auto 14px;padding:0 8px}

/* ── POLAROIDS HERO ── */
.pol{position:absolute;z-index:4;filter:drop-shadow(0 12px 28px rgba(0,0,0,.55))}
.pol .pf{background:#F7EDD8;padding:10px 10px 32px;transform:rotate(0deg);position:relative}
.pol .pf img{width:100%;display:block;aspect-ratio:1/1;object-fit:cover}
.pol .pcap{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:.78rem;
  color:var(--terra);text-align:center;letter-spacing:.05em;margin-top:6px}
.pol.p1{width:140px;left:3%;top:18%;transform:rotate(-6deg)}
.pol.p2{width:130px;right:4%;top:24%;transform:rotate(7deg)}
@media(max-width:900px){.pol{display:none}}

/* ── MOBILE PHOTO STRIP ── */
.photo-strip{position:relative;z-index:5;width:100%;max-width:100vw;
  padding:14px 0 28px;overflow:hidden}
.strip-inner{display:flex;gap:14px;padding:8px 24px 12px;
  overflow-x:scroll;overflow-y:visible;scroll-snap-type:x mandatory;
  -webkit-overflow-scrolling:touch;touch-action:pan-x;
  scrollbar-width:none}
.strip-inner::-webkit-scrollbar{display:none}
.pol-s{flex-shrink:0;width:155px;scroll-snap-align:center;
  filter:drop-shadow(0 8px 18px rgba(0,0,0,.5))}
.pol-s .pf{background:#F7EDD8;padding:9px 9px 24px}
.pol-s .pf img{width:100%;aspect-ratio:1/1;object-fit:cover;display:block}
.pol-s .pcap{font-family:'Cormorant Garamond',serif;font-style:italic;
  font-size:.72rem;color:var(--terra);text-align:center;letter-spacing:.04em;margin-top:5px}
.pol-s:nth-child(odd){transform:rotate(-3deg)}
.pol-s:nth-child(even){transform:rotate(3deg)}
@media(min-width:901px){.photo-strip{display:none}}

/* ── GIFT GRID ── */
.gifts-wrap{max-width:1080px;margin:0 auto;padding:30px 24px 80px;position:relative;z-index:5}
.gifts{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-bottom:28px}
.gift{
  position:relative;
  display:block;text-decoration:none;color:inherit;
  background:linear-gradient(160deg,rgba(247,237,216,.05) 0%,rgba(196,144,48,.03) 100%);
  border:1px solid rgba(196,144,48,.22);
  border-radius:2px;padding:28px 22px 26px;text-align:center;
  transition:transform .35s cubic-bezier(.22,.61,.36,1),border-color .35s ease,box-shadow .35s ease,background .35s ease;
  overflow:hidden;
}
.gift::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at top,rgba(196,144,48,.08),transparent 60%);
  opacity:0;transition:opacity .4s ease;pointer-events:none;
}
.gift:hover{
  transform:translateY(-6px);
  border-color:rgba(196,144,48,.55);
  box-shadow:0 14px 38px rgba(0,0,0,.45),0 0 0 1px rgba(196,144,48,.08);
  background:linear-gradient(160deg,rgba(247,237,216,.08) 0%,rgba(196,144,48,.05) 100%);
}
.gift:hover::before{opacity:1}

.gift-star{position:absolute;top:14px;right:16px;font-size:.85rem;color:var(--gold);opacity:.55}

.gift-amount{
  font-family:'Cormorant Garamond',serif;font-weight:300;font-style:italic;
  font-size:2.2rem;color:var(--gold);line-height:1;margin-bottom:6px;
  letter-spacing:.01em;
}
.gift-amount .cur{font-size:1rem;vertical-align:.6em;margin-right:3px;opacity:.75}
.gift-amount .mxn{font-size:.72rem;font-style:normal;letter-spacing:.18em;
  text-transform:uppercase;color:rgba(196,144,48,.6);
  font-family:'Jost',sans-serif;display:inline-block;margin-left:6px;vertical-align:.4em}

.gift-desc{
  font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;
  color:rgba(232,216,184,.78);line-height:1.5;margin:10px 0 22px;min-height:3em;
}

.gift-btn{
  display:inline-flex;align-items:center;gap:10px;
  padding:11px 22px;
  background:transparent;
  color:var(--gold);
  border:1px solid rgba(196,144,48,.5);border-radius:2px;
  font-family:'Jost',sans-serif;font-size:.66rem;
  letter-spacing:.24em;text-transform:uppercase;font-weight:500;
  text-decoration:none;cursor:pointer;
  transition:all .3s ease;
}
.gift:hover .gift-btn{
  background:linear-gradient(135deg,var(--gold) 0%,var(--terra) 100%);
  color:#1A0E06;border-color:transparent;
  box-shadow:0 4px 14px rgba(196,144,48,.3);
}
.gift-btn-ic{transition:transform .3s ease;font-size:.85rem}
.gift:hover .gift-btn-ic{transform:translateX(3px)}

/* ── CUSTOM AMOUNT CARD ── */
.gift-custom{
  margin-top:8px;padding:38px 32px;text-align:center;
  background:linear-gradient(135deg,rgba(196,144,48,.08) 0%,rgba(196,90,26,.06) 100%);
  border:1px solid rgba(196,144,48,.32);border-radius:2px;
  position:relative;overflow:hidden;
}
.gift-custom::before{
  content:'✦';position:absolute;top:18px;left:50%;transform:translateX(-50%);
  font-size:1.4rem;color:var(--gold);opacity:.5;
}
.gift-custom h3{
  font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;
  font-size:1.7rem;color:#F2E4C4;margin:14px 0 8px;letter-spacing:.01em;
}
.gift-custom p{
  font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.05rem;
  color:rgba(232,216,184,.72);margin-bottom:22px;max-width:440px;
  margin-left:auto;margin-right:auto;line-height:1.55;
}
.gift-custom-btn{
  display:inline-flex;align-items:center;gap:12px;
  padding:14px 30px;
  background:linear-gradient(135deg,var(--gold) 0%,var(--terra) 100%);
  color:#1A0E06;border:none;border-radius:2px;
  font-family:'Jost',sans-serif;font-size:.72rem;
  letter-spacing:.24em;text-transform:uppercase;font-weight:500;
  text-decoration:none;cursor:pointer;
  box-shadow:0 4px 18px rgba(196,144,48,.22);
  transition:transform .25s ease,box-shadow .25s ease,filter .25s ease;
}
.gift-custom-btn:hover{
  transform:translateY(-2px);
  box-shadow:0 8px 28px rgba(196,144,48,.35);
  filter:brightness(1.05);
}
.gift-custom-btn-ic{font-size:.95rem;transition:transform .25s ease}
.gift-custom-btn:hover .gift-custom-btn-ic{transform:translateX(4px)}

/* ── INFO PANEL ── */
.info{
  max-width:680px;margin:60px auto 0;padding:30px 28px;
  background:rgba(247,237,216,.025);
  border-top:1px solid rgba(196,144,48,.18);
  border-bottom:1px solid rgba(196,144,48,.18);
  text-align:center;
}
.info-lbl{font-family:'Jost',sans-serif;font-size:.62rem;letter-spacing:.28em;
  text-transform:uppercase;color:rgba(196,144,48,.7);margin-bottom:12px}
.info p{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;
  color:rgba(232,216,184,.78);line-height:1.7;margin-bottom:10px}
.info p:last-child{margin-bottom:0}
.info strong{color:var(--gold);font-weight:400;font-style:normal;
  font-family:'Jost',sans-serif;font-size:.86rem;letter-spacing:.04em}
.info-icons{display:flex;justify-content:center;align-items:center;gap:20px;
  margin-top:18px;flex-wrap:wrap}
.info-tag{font-family:'Jost',sans-serif;font-size:.6rem;letter-spacing:.18em;
  text-transform:uppercase;color:rgba(247,237,216,.55);
  display:inline-flex;align-items:center;gap:6px}
.info-tag-dot{width:5px;height:5px;background:var(--gold);border-radius:50%;opacity:.7}

/* ── FOOTER ── */
footer{padding:48px 24px 36px;text-align:center;position:relative;z-index:5;
  border-top:1px solid rgba(196,144,48,.12);margin-top:40px}
.fn{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:2rem;
  font-weight:300;color:var(--gold);margin-bottom:8px}
.fd{font-size:.63rem;letter-spacing:.28em;text-transform:uppercase;
  color:rgba(196,144,48,.45);margin-bottom:22px}
.fl-link{font-family:'Jost',sans-serif;font-size:.65rem;letter-spacing:.24em;
  text-transform:uppercase;color:rgba(247,237,216,.55);text-decoration:none;
  display:inline-flex;align-items:center;gap:8px;transition:color .2s}
.fl-link:hover{color:var(--gold)}

/* ── ANIMATIONS ── */
@keyframes tw-a{0%,100%{opacity:.3;transform:scale(.85)}50%{opacity:1;transform:scale(1.15)}}
@keyframes tw-b{0%,100%{opacity:.45;transform:scale(.9)}50%{opacity:.9;transform:scale(1.1)}}
@keyframes float-m{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-8px) rotate(2deg)}}
@keyframes float-p{0%,100%{transform:translate(0,0)}50%{transform:translate(8px,-6px)}}
@keyframes spin-s{0%,100%{transform:rotate(0deg) scale(1)}50%{transform:rotate(180deg) scale(1.12)}}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .gifts{grid-template-columns:repeat(2,1fr);gap:16px}
  .gift{padding:24px 18px 22px}
  .gift-amount{font-size:2rem}
  .gift-desc{font-size:.95rem;min-height:auto}
  .hero{padding:100px 18px 40px}
}
@media(max-width:520px){
  .gifts{grid-template-columns:1fr;gap:14px}
  .gift{padding:26px 24px 24px}
  .gift-amount{font-size:2.3rem}
  .gift-desc{min-height:auto;margin-bottom:18px}
  .gift-custom{padding:32px 22px}
  .gift-custom h3{font-size:1.45rem}
  .info{padding:26px 20px}
  .body-txt{font-size:1.05rem}
}
</style>
</head>
<body>
