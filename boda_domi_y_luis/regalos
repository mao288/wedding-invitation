  <div class="hero-content">
    <p class="lbl rv">Mesa de regalos</p>
    <h1 class="title rv d1">Nuestra <em>luna</em> de miel</h1>
    <div class="gd rv d2"><div class="gl"></div><div class="gdd"></div><div class="gdm"></div><div class="gdd"></div><div class="gl r"></div></div>
