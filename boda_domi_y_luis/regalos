<script>
/* ── STARFIELD CANVAS ── */
(() => {
  const c = document.getElementById('starfield');
  if(!c) return;
  const ctx = c.getContext('2d');
  let stars = [];
  const PAL = ['#C49030','#C45A1A','#F2E4C4','#6B7A42'];
  function rnd(a,b){return Math.random()*(b-a)+a}
  function resize(){
    c.width = innerWidth;
    c.height = innerHeight;
    stars = [];
    const count = Math.floor((innerWidth*innerHeight)/4500);
    for(let i=0;i<count;i++){
      const col = PAL[Math.floor(Math.random()*PAL.length)];
      const sz = Math.random();
      stars.push({
        x: rnd(0,c.width),
        y: rnd(0,c.height),
        r: sz<.7 ? rnd(.4,1) : rnd(1,1.8),
        col: col,
        op: rnd(.2,.7),
        sp: rnd(.005,.018),
        ph: rnd(0,Math.PI*2)
      });
    }
  }
  window.addEventListener('resize', resize, {passive:true});
  resize();
  function loop(t){
    ctx.clearRect(0,0,c.width,c.height);
    stars.forEach(s => {
      const tw = Math.sin(t*s.sp + s.ph)*.4 + .6;
      ctx.globalAlpha = s.op * tw;
      ctx.fillStyle = s.col;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
      ctx.fill();
    });
    ctx.globalAlpha = 1;
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
})();

/* ── NAV + REVEAL ── */
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 60));
const obs = new IntersectionObserver(e => e.forEach(x => {
  if(x.isIntersecting){ x.target.classList.add('vis'); obs.unobserve(x.target); }
}), {threshold:.1});
document.querySelectorAll('.rv').forEach(el => obs.observe(el));

/* On load, immediately reveal hero elements above the fold */
window.addEventListener('load', () => {
  document.querySelectorAll('.hero .rv').forEach(el => el.classList.add('vis'));
});
</script>
