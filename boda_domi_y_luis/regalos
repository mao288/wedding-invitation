      </g>
    </svg>

    <!-- Plane with trail, left side -->
    <svg width="260" height="160" style="position:absolute;left:5%;top:30%" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 260 160">
      <g style="animation:float-p 6s ease-in-out infinite 0s">
        <!-- contrail (dashed arc) -->
        <path d="M 10 130 Q 90 60, 200 50" stroke="rgba(196,144,48,.35)" stroke-width="1.2" stroke-dasharray="4,5" fill="none" stroke-linecap="round"/>
        <path d="M 10 130 Q 90 60, 200 50" stroke="rgba(247,237,216,.15)" stroke-width="3" fill="none" stroke-linecap="round" opacity=".4"/>
        <!-- plane silhouette, simple -->
