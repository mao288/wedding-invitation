        </g>
      </g>
    </svg>

    <!-- Ambient stars sprinkled -->
    <svg width="100%" height="100%" preserveAspectRatio="none" style="position:absolute;inset:0" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12%"  cy="18%" r="1.4" fill="#C49030" style="animation:tw-a 2.1s ease-in-out infinite .3s"/>
      <circle cx="22%"  cy="9%"  r="1.1" fill="#C45A1A" style="animation:tw-b 1.8s ease-in-out infinite .9s"/>
      <circle cx="48%"  cy="6%"  r="1.6" fill="#C49030" style="animation:tw-a 2.4s ease-in-out infinite 1.4s"/>
      <circle cx="72%"  cy="11%" r="1.2" fill="#6B7A42" style="animation:tw-b 2s ease-in-out infinite .6s"/>
      <circle cx="88%"  cy="45%" r="1.3" fill="#C49030" style="animation:tw-a 1.9s ease-in-out infinite 1.1s"/>
      <circle cx="6%"   cy="58%" r="1.2" fill="#C45A1A" style="animation:tw-b 2.2s ease-in-out infinite .4s"/>
      <circle cx="32%"  cy="72%" r="1.4" fill="#C49030" style="animation:tw-a 1.7s ease-in-out infinite 1.5s"/>
      <circle cx="93%"  cy="78%" r="1.1" fill="#6B7A42" style="animation:tw-b 2.3s ease-in-out infinite .8s"/>
      <!-- 4-pt star ornament -->
      <polygon points="155,40 156.5,48 164,49.5 156.5,51 155,59 153.5,51 146,49.5 153.5,48"
        fill="rgba(196,144,48,.45)" style="animation:spin-s 7s ease-in-out infinite;transform-box:fill-box;transform-origin:center"/>
    </svg>
  </div>

  <!-- Hero polaroids (desktop only) -->
  <div class="pol p1">
    <div class="pf">
      <img src="https://res.cloudinary.com/diobgaxfl/image/upload/q_auto/f_auto/v1775561160/IMG-20260406-WA0046_gku3jt.jpg" alt="Viaje juntos" loading="lazy">
